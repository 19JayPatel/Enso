<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Header Section -->
    <TextView
        android:id="@+id/tv_salons_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Salons"
        android:textColor="@color/black"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_registered_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:text="0 registered"
        android:textColor="#8E8E8E"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/tv_salons_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_salons_title" />

    <!-- Search Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_search"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#F5F5F5"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_salons_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#8E8E8E" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="Search salons, owners..."
                android:inputType="text"
                android:textColor="#000000"
                android:textColorHint="#8E8E8E"
                android:textSize="14sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:id="@+id/scroll_filters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/card_search">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- All Filter -->
            <TextView
                android:id="@+id/filter_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_white_rounded_12"
                android:backgroundTint="#1A1A1A"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="All"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Active Filter -->
            <TextView
                android:id="@+id/filter_active"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_white_rounded_12"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="Active"
                android:textColor="#8E8E8E"
                android:textSize="14sp" />

            <!-- Pending Filter -->
            <TextView
                android:id="@+id/filter_pending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_white_rounded_12"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="Pending"
                android:textColor="#8E8E8E"
                android:textSize="14sp" />

            <!-- Suspended Filter -->
            <TextView
                android:id="@+id/filter_suspended"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_white_rounded_12"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:text="Suspended"
                android:textColor="#8E8E8E"
                android:textSize="14sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Salon List RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_salons"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="24dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scroll_filters"
        tools:listitem="@layout/item_salon" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_add_salon"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_white_rounded_16"
        android:backgroundTint="#A46C54"
        android:drawableStart="@drawable/ic_add"
        android:drawablePadding="12dp"
        android:paddingHorizontal="24dp"
        android:text="Add New Salon"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

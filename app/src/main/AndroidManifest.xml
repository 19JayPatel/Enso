<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".EnsoApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/splash_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/splash_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.Enso"
        tools:targetApi="31">

        <!-- Splash Screen (Main Entry Point) -->
        <activity
            android:name=".auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Enso">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".admin.AdminMainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name=".admin.AddSalonActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- Salon Owner Activities -->
        <activity
            android:name=".owner.SalonOwnerMainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan" />

        <!-- Navigation Flow Activities -->
        <activity
            android:name=".owner.AddNewServiceActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".owner.AddServicePricingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".owner.AddServiceReviewActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".owner.ServicePublishedActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Auth Activities -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".auth.SignupActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Customer Activities -->
        <activity
            android:name=".customer.activities.MainActivity"
            android:exported="false"
            android:label="@string/app_name" />

        <activity
            android:name=".customer.activities.ChooseStylistActivity"
            android:exported="false" />

        <activity
            android:name=".customer.activities.DateTimeActivity"
            android:exported="false" />

        <activity
            android:name=".customer.activities.ConfirmBookingActivity"
            android:exported="false" />

        <activity
            android:name=".customer.activities.MapViewActivity"
            android:exported="false" />

        <activity
            android:name=".customer.activities.AllSalonActivity"
            android:exported="false" />

        <activity
            android:name=".customer.activities.SearchResultActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".customer.activities.SalonDetailsActivity"
            android:exported="false" />

        <activity
            android:name=".customer.activities.ReceiptActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

    </application>

</manifest>